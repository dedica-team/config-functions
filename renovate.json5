{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    // No commits like "chore(deps): [...]"
    ":semanticCommitsDisabled",
    // Use hashes as references to GitHub actions as tags could be changed after release.
    "helpers:pinGitHubActionDigests",
    // Use hashes as references to Docker Images as tags could be changed after release.
    "docker:pinDigests"
  ],

  // Do not limit the number of dependency update Pull Requests.
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,

  "labels": [
    "Dependencies",
    "skip changelog check"
  ],

  "customManagers": [
    // Update Java version references in SDKMan config file (.sdkmanrc).
    // Details:
    // - https://www.innoq.com/en/articles/2024/05/renovate/#supportforjbangsdkmanandthefrontend-maven-plugin
    // - https://github.com/renovatebot/renovate/discussions/18835
    {
      "customType": "regex",
      "description": "Updates Java versions in .sdkmanrc files.",
      "managerFilePatterns": [
        "/^\\.sdkmanrc$/"
      ],
      "matchStrings": [
        "java=(?<currentValue>\\d+\\.\\d+\\.\\d+)(?<suffix>-.*)\\n"
      ],
      "datasourceTemplate": "java-version",
      "depNameTemplate": "java",
      // Remove suffix (if it exists) from new version.
      "extractVersionTemplate": "^(?<version>\\d+\\.\\d+\\.\\d+)"
    },

    // Update Maven dependency version examples in README code blocks:
    // ```xml
    // <dependency>
    //    <groupId>team.dedica</groupId>
    //    <artifactId>config-functions</artifactId>
    //    <version>1.2.3</version>
    // </dependency>
    // ```
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/README\\.md$/"
      ],
      "matchStrings": [
        "```xml\\n[\\s\\S]*?<groupId>(?<groupId>.*?)</groupId>\\s*<artifactId>(?<artifactId>.*?)</artifactId>\\s*<version>(?<currentValue>.*?)</version>[\\s\\S]*?```"
      ],
      "datasourceTemplate": "maven",
      "depNameTemplate": "{{groupId}}:{{artifactId}}"
    }
  ],

  "packageRules": [
    {
      "matchPackageNames": ["org.springframework.boot:spring-boot-dependencies"],
      // Although config-functions might work with Spring Boot 4, it is currently
      // developed for and tested with Spring Boot 3.
      "allowedVersions": "<4.0",
    }
  ]
}
