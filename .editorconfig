root = true

[*]
indent_size = 2
indent_style = space
insert_final_newline = true

[*.xml]
indent_size = 2
indent_style = space

[*.java]
indent_size = 4
indent_style = space

# IntelliJ specific formatting settings:
#     https://www.jetbrains.com/help/idea/editorconfig.html

# Do not indent following lines in a text block.
ij_java_align_multiline_text_blocks = true

# Indentation when breaking statements into multiple lines.
ij_java_continuation_indent_size = 4

# Do not automatically break long lines as may occur anywhere (where technically possible) and reduce readability.
ij_java_wrap_long_lines = false

# Split long parameter declarations into multiple lines:
#
# myMethod(
#     A p1,
#     B p2
# )
ij_java_method_parameters_wrap = on_every_item
ij_java_method_parameters_new_line_after_left_paren = true
ij_java_method_parameters_right_paren_on_new_line = true
ij_java_align_multiline_parameters = true

# Generate final variables per default.
ij_java_generate_final_locals = true
ij_java_generate_final_parameters = true

# Do not use imports on demand (with "*").
ij_java_class_count_to_use_import_on_demand = 99
ij_java_names_count_to_use_import_on_demand = 99
